{
  "name": "kungeskill",
  "version": "0.13.1",
  "description": "Manage Claude Code skills via symlinks — install, remove, update skills from a marketplace cache",
  "main": "src/cli.js",
  "bin": {
    "kungeskill": "src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/**/*.js",
    "plugins/**/*",
    ".claude-plugin/**/*",
    "web/dist/**/*"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "list": "node src/cli.js list",
    "init": "node src/cli.js init",
    "web": "node src/cli.js web",
    "build:server": "tsc -p tsconfig.server.json",
    "prepublishOnly": "node src/cli.js --version",
    "test": "vitest run"
  },
  "keywords": [
    "claude-code",
    "skills",
    "marketplace",
    "symlink",
    "skill-manager"
  ],
  "author": "kungeskills",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunge2013/skills"
  },
  "bugs": {
    "url": "https://github.com/kunge2013/skills/issues"
  },
  "homepage": "https://github.com/kunge2013/skills#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.52.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.2",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^0.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "openai": "^4.104.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
