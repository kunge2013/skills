{
  "name": "kungeskill",
  "version": "0.10.0",
  "description": "Manage Claude Code skills via symlinks — install, remove, update skills from a marketplace cache",
  "main": "src/cli.js",
  "bin": {
    "kungeskill": "src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/**/*.js",
    "plugins/**/*",
    ".claude-plugin/**/*",
    "web/dist/**/*"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "list": "node src/cli.js list",
    "init": "node src/cli.js init",
    "prepublishOnly": "node src/cli.js --version",
    "test": "vitest run"
  },
  "keywords": [
    "claude-code",
    "skills",
    "marketplace",
    "symlink",
    "skill-manager"
  ],
  "author": "kungeskills",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kunge2013/skills"
  },
  "bugs": {
    "url": "https://github.com/kunge2013/skills/issues"
  },
  "homepage": "https://github.com/kunge2013/skills#readme",
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
